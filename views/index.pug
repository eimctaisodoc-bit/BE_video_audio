doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Real-Time Voice Call

    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: Arial, sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #e2e8f0, #f8fafc);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
      }

      .card {
        width: 100%;
        max-width: 420px;
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.08);
      }

      h1 {
        font-size: 28px;
        margin-bottom: 8px;
        color: #0f172a;
      }

      p {
        color: #64748b;
        margin-bottom: 16px;
      }

      input {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        outline: none;
        margin-bottom: 14px;
        font-size: 15px;
      }

      .status {
        padding: 12px 14px;
        border-radius: 14px;
        background: #f1f5f9;
        margin-bottom: 16px;
        color: #0f172a;
        font-size: 14px;
      }

      .btns {
        display: flex;
        gap: 12px;
      }

      button {
        flex: 1;
        padding: 14px;
        border: none;
        border-radius: 14px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 600;
      }

      .call-btn {
        background: #16a34a;
        color: white;
      }

      .end-btn {
        background: #dc2626;
        color: white;
      }

      .mute-btn {
        background: #0f172a;
        color: white;
        margin-top: 12px;
        width: 100%;
      }

      audio {
        display: flex;
      }
  body
    .card
      h1 Voice Call
      p Join same room on 2 tabs/devices for testing

      input(type="text" id="roomId" placeholder="Enter room id" value="room1")
      .status#status Status: Idle

      .btns
        button.call-btn(type="button" onclick="startCall()") Start Call
        button.end-btn(type="button" onclick="endCall()") End Call

      button.mute-btn(type="button" id="muteBtn" onclick="toggleMute()") Mute Mic

      audio#remoteAudio(autoplay playsinline)

    script(src="/socket.io/socket.io.js")
    script(src="/client.js")